# Bearer-token fångad från en inloggad Viva Engage-session.
# Hämtas via DevTools (Network-fliken) -> ett anrop till www.yammer.com/api/...
# -> Request Headers -> Authorization: Bearer <token>. Klistra in token utan "Bearer ".
# Token är kortlivad - kör hela skrapet i ett svep.
YAMMER_TOKEN=

# Bas-URL för legacy-API:t. Behöver normalt inte ändras.
YAMMER_API_BASE=https://www.yammer.com/api/v1
